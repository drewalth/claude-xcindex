# Swift build output
service/.build/
# The test fixture is a SwiftPM package; `swift build` may be run in it
# during development. Its build artifacts and resolved manifest are
# generated and should not be committed.
service/Tests/Fixtures/**/.build/
service/Tests/Fixtures/**/Package.resolved

# semantic-release sentinel (created in CI only)
.release-version

# The xcindex binary is cached here at runtime by bin/run (never committed)
bin/xcindex
bin/xcindex.download.*

# Pre-Swift-consolidation Node/TS implementation (removed in v1.x); guard
# against accidental revival from stashes, old branches, or npm installs.
mcp/
.DS_Store
*.log

# Local Claude Code settings (user-specific permissions, scheduler state).
.claude/

# Coverage summaries regenerated by `swift test` — docs/coverage.md is the tracked view.
tests/coverage/coverage-summary.json
tests/coverage/*-coverage-summary.json