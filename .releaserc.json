{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      { "preset": "conventionalcommits" }
    ],
    [
      "@semantic-release/release-notes-generator",
      { "preset": "conventionalcommits" }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this project are documented here. This file is generated from commit messages via semantic-release."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/bump-version.mjs ${nextRelease.version}",
        "publishCmd": "echo ${nextRelease.version} > ${env.GITHUB_WORKSPACE:-.}/.release-version"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          ".claude-plugin/plugin.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
