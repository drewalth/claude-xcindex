#!/usr/bin/env bash
# xcindex-doctor: first-run / troubleshooting diagnostic for claude-xcindex.
#
# Checks, in order:
#   1. Xcode is installed and selected.
#   2. `libIndexStore.dylib` is reachable from xcrun.
#   3. `swiftc` is on the path (required to build from source).
#   4. `sourcekit-lsp` is discoverable (required for plan_rename
#      reconciliation beyond the indexstore-only baseline).
#   5. The xcindex binary is present and executable.
#   6. An Xcode project can be located (either via `--project` or by
#      scanning the current working directory).
#   7. The index store for that project exists under DerivedData.
#   8. Source files are not newer than the index (freshness).
#   9. For .xcodeproj-only projects: a build-server bridge
#      (compile_commands.json or buildServer.json) exists so
#      sourcekit-lsp can answer semantic queries. Missing bridge is a
#      soft warning — passing --install offers to `brew install
#      xcode-build-server` and run `xcode-build-server config` for you.
#
# Each check prints `[ OK ]` or `[FAIL]` with a remediation hint. Exits
# with status 0 if all checks pass, 1 otherwise.
#
# Usage:
#   bin/xcindex-doctor                           # auto-detect project
#   bin/xcindex-doctor --project path/to/Foo.xcodeproj
#   bin/xcindex-doctor --project path/to/Foo.xcworkspace
#   bin/xcindex-doctor --install                 # offer to install missing bridge

set -uo pipefail

# -------- config ------------------------------------------------------------

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
PROJECT=""
INSTALL=0
EXIT=0

# -------- args --------------------------------------------------------------

while [[ $# -gt 0 ]]; do
    case "$1" in
        --project) PROJECT="${2:-}"; shift 2 ;;
        --install) INSTALL=1; shift ;;
        -h|--help)
            sed -n '2,/^$/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "unknown argument: $1" >&2; exit 2 ;;
    esac
done

# -------- formatting --------------------------------------------------------

green() { printf '\033[32m%s\033[0m' "$1"; }
red()   { printf '\033[31m%s\033[0m' "$1"; }
dim()   { printf '\033[2m%s\033[0m'  "$1"; }

pass() { echo "  [$(green ' OK ')] $1"; }
fail() { echo "  [$(red  'FAIL')] $1"; [[ -n "${2:-}" ]] && echo "          $(dim "→ $2")"; EXIT=1; }
info() { echo "  [$(dim 'INFO')] $1"; }
section() { echo; echo "== $1 =="; }

# -------- checks ------------------------------------------------------------

section "Xcode"

if ! command -v xcode-select >/dev/null 2>&1; then
    fail "xcode-select not found." "Install Xcode from the App Store."
else
    if xcode_dir=$(xcode-select -p 2>/dev/null); then
        pass "Xcode selected: $xcode_dir"
    else
        fail "No Xcode selected." "Run: sudo xcode-select -s /Applications/Xcode.app"
    fi
fi

if command -v xcodebuild >/dev/null 2>&1; then
    xb_version=$(xcodebuild -version 2>/dev/null | head -1)
    pass "$xb_version"
else
    fail "xcodebuild not on PATH." "Install Xcode command line tools: xcode-select --install"
fi

# -------- libIndexStore -----------------------------------------------------

section "libIndexStore"

lib_path=""
if clang_path=$(xcrun --find clang 2>/dev/null); then
    # clang is at .../usr/bin/clang; the dylib lives at .../usr/lib/libIndexStore.dylib
    lib_candidate="$(dirname "$(dirname "$clang_path")")/lib/libIndexStore.dylib"
    if [[ -f "$lib_candidate" ]]; then
        lib_path="$lib_candidate"
    fi
fi

if [[ -z "$lib_path" ]]; then
    for fallback in \
        /Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/lib/libIndexStore.dylib \
        /Applications/Xcode.app/Contents/SharedFrameworks/IndexStore.framework/Versions/A/IndexStore \
        /Applications/Xcode-beta.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/lib/libIndexStore.dylib
    do
        [[ -f "$fallback" ]] && { lib_path="$fallback"; break; }
    done
fi

if [[ -n "$lib_path" ]]; then
    pass "libIndexStore: $lib_path"
else
    fail "libIndexStore.dylib not found." "Reinstall Xcode, or run: sudo xcode-select -s /Applications/Xcode.app"
fi

# -------- swiftc ------------------------------------------------------------

section "swiftc"

if swiftc_path=$(xcrun --find swiftc 2>/dev/null); then
    swiftc_version=$("$swiftc_path" --version 2>/dev/null | head -1)
    pass "$swiftc_version"
else
    fail "swiftc not found via xcrun." "Install Xcode command line tools: xcode-select --install"
fi

# -------- sourcekit-lsp -----------------------------------------------------
#
# plan_rename's LSP reconciliation tier calls textDocument/references
# against a live sourcekit-lsp process. Without it we still return
# green-indexstore results, but they're flagged reconciliation_unavailable.

section "sourcekit-lsp"

sklsp_path=""
# The env override must be authoritative when it's set: if the user
# points at a file that exists but isn't executable, falling through
# to xcrun hides the real misconfiguration. Diagnose both cases
# explicitly — the warning code in xcindex maps to a distinct
# `sourcekit_lsp_binary_not_executable` remediation (`chmod +x`)
# that's unrelated to "install via Xcode."
if [[ -n "${SOURCEKIT_LSP_PATH:-}" ]]; then
    if [[ ! -e "${SOURCEKIT_LSP_PATH}" ]]; then
        fail "SOURCEKIT_LSP_PATH=${SOURCEKIT_LSP_PATH} does not exist." \
             "Unset the env var or point it at a real sourcekit-lsp binary."
    elif [[ ! -x "${SOURCEKIT_LSP_PATH}" ]]; then
        fail "SOURCEKIT_LSP_PATH=${SOURCEKIT_LSP_PATH} is not executable." \
             "Run: chmod +x ${SOURCEKIT_LSP_PATH}"
    else
        sklsp_path="$SOURCEKIT_LSP_PATH"
    fi
elif xcrun_path=$(xcrun --find sourcekit-lsp 2>/dev/null); then
    [[ -x "$xcrun_path" ]] && sklsp_path="$xcrun_path"
elif which_path=$(command -v sourcekit-lsp 2>/dev/null); then
    sklsp_path="$which_path"
fi

if [[ -n "$sklsp_path" ]]; then
    pass "sourcekit-lsp: $sklsp_path"
    # `sourcekit-lsp --version` is supported on recent toolchains; older
    # ones exit 0 on --help and nonzero on --version. Tolerate both.
    if sklsp_version=$("$sklsp_path" --version 2>/dev/null | head -1); then
        [[ -n "$sklsp_version" ]] && info "Version: $sklsp_version"
    fi
elif [[ -z "${SOURCEKIT_LSP_PATH:-}" ]]; then
    fail "sourcekit-lsp not found on PATH, via xcrun, or at SOURCEKIT_LSP_PATH." \
         "plan_rename will emit sourcekit_lsp_not_found warnings. Install via the Swift toolchain or Xcode."
fi

# -------- xcindex binary ----------------------------------------------------

section "xcindex binary"

binary="${PLUGIN_ROOT}/bin/xcindex"
if [[ -x "$binary" ]]; then
    pass "Binary present: $binary"
else
    source_build="${PLUGIN_ROOT}/service/.build/release/xcindex"
    if [[ -x "$source_build" ]]; then
        info "Source build at $source_build — bin/run will symlink it on next launch."
    else
        fail "No xcindex binary yet." "Run ./build.sh, or let bin/run download one on first launch."
    fi
fi

# -------- project -----------------------------------------------------------

section "Xcode project"

if [[ -z "$PROJECT" ]]; then
    # Scan CWD and one level up, prefer .xcworkspace.
    for d in "$(pwd)" "$(dirname "$(pwd)")"; do
        for ext in xcworkspace xcodeproj; do
            found=$(find "$d" -maxdepth 2 -name "*.$ext" ! -path "*/Pods/*" ! -path "*/.git/*" 2>/dev/null | head -1)
            if [[ -n "$found" ]]; then
                PROJECT="$found"
                break 2
            fi
        done
    done
fi

if [[ -z "$PROJECT" ]]; then
    info "No .xcodeproj or .xcworkspace found near CWD — pass --project <path> to check index freshness."
    echo
    [[ $EXIT -eq 0 ]] && echo "All environment checks passed." || echo "Some checks failed; see above."
    exit $EXIT
fi

pass "Project: $PROJECT"

# -------- index store -------------------------------------------------------

section "Index store"

project_name=$(basename "$PROJECT" | sed 's/\.[^.]*$//')
dd_base="$HOME/Library/Developer/Xcode/DerivedData"
custom=$(defaults read com.apple.dt.Xcode IDECustomDerivedDataLocation 2>/dev/null || true)
[[ -n "$custom" ]] && dd_base="$custom"

dd_dir=$(ls -dt "${dd_base}/${project_name}-"* 2>/dev/null | head -1)

if [[ -z "$dd_dir" ]]; then
    fail "No DerivedData folder for '$project_name' under $dd_base." \
         "Open the project in Xcode and build it at least once (Cmd+B)."
    echo
    echo "Some checks failed; see above."
    exit 1
fi

index_store="${dd_dir}/Index.noindex/DataStore"
if [[ ! -d "$index_store" ]]; then
    fail "DerivedData folder exists but has no Index.noindex/DataStore." \
         "Build with indexing enabled. In Xcode: Settings → General → Indexing."
    echo
    echo "Some checks failed; see above."
    exit 1
fi

index_mtime_human=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$index_store" 2>/dev/null || echo "unknown")
pass "Index store: $index_store"
pass "Last indexed: $index_mtime_human"

# -------- freshness ---------------------------------------------------------

section "Freshness"

index_epoch=$(stat -f "%m" "$index_store" 2>/dev/null || echo 0)
project_dir=$(dirname "$PROJECT")
stale=0
# Pre-flight the traversal so a vanished/denied path fails loudly
# rather than silently reporting 0 stale files. The main loop below
# still redirects errors to /dev/null so mid-traversal transients
# (file deleted between readdir + stat) don't spam the terminal.
if ! find "$project_dir" -name "*.swift" -not -path "*/.git/*" -not -path "*/DerivedData/*" -print0 >/dev/null 2>&1; then
    fail "find traversal of $project_dir failed." \
         "Check permissions and retry; freshness results may be incomplete."
else
    while IFS= read -r -d '' f; do
        file_epoch=$(stat -f "%m" "$f" 2>/dev/null || echo 0)
        (( file_epoch > index_epoch )) && stale=$((stale + 1))
    done < <(find "$project_dir" -name "*.swift" -not -path "*/.git/*" -not -path "*/DerivedData/*" -print0 2>/dev/null)

    if (( stale == 0 )); then
        pass "No Swift files newer than the index."
    else
        fail "$stale Swift file(s) newer than the index." \
             "Build the project in Xcode to refresh, or expect stale results from xcindex_* queries."
    fi
fi

# -------- build-server bridge -----------------------------------------------
#
# sourcekit-lsp answers semantic queries from the build context it can
# reconstruct for the workspace. SwiftPM packages work out of the box.
# .xcodeproj / .xcworkspace projects need either a committed
# `compile_commands.json` (from xcodebuild) or a `buildServer.json`
# generated by xcode-build-server. Without one, textDocument/references
# returns `[]` and plan_rename downgrades to reconciliation_empty.

section "Build-server bridge"

workspace_root="$project_dir"
has_package=0
has_xcode=0
has_bridge=0
bridge_kind=""

[[ -f "$workspace_root/Package.swift" ]] && has_package=1
if compgen -G "$workspace_root/*.xcodeproj" >/dev/null 2>&1 \
   || compgen -G "$workspace_root/*.xcworkspace" >/dev/null 2>&1; then
    has_xcode=1
fi

if [[ -f "$workspace_root/compile_commands.json" ]]; then
    has_bridge=1; bridge_kind="compile_commands.json"
elif [[ -f "$workspace_root/buildServer.json" ]]; then
    has_bridge=1; bridge_kind="buildServer.json"
fi

if (( has_package == 1 )); then
    pass "SPM package — sourcekit-lsp resolves the build context directly."
elif (( has_xcode == 1 && has_bridge == 1 )); then
    pass "Bridge present: $bridge_kind (sourcekit-lsp will see the build context)."
elif (( has_xcode == 1 )); then
    # Missing bridge for .xcodeproj-only workspace. Soft-fail, then
    # optionally offer to install.
    fail "No compile_commands.json or buildServer.json at $workspace_root." \
         "plan_rename will emit compile_commands_missing for this project."

    # xcode-build-server availability
    if command -v xcode-build-server >/dev/null 2>&1; then
        info "xcode-build-server is installed — run: xcode-build-server config -project $PROJECT -scheme <scheme>"
    elif ! command -v brew >/dev/null 2>&1; then
        info "Install Homebrew first: https://brew.sh — then: brew install xcode-build-server"
    elif (( INSTALL == 1 )); then
        echo
        echo "  Installing xcode-build-server via Homebrew…"
        if brew install xcode-build-server; then
            pass "xcode-build-server installed."
            info "Run: xcode-build-server config -project $PROJECT -scheme <scheme>"
        else
            fail "brew install xcode-build-server failed." "See the brew output above."
        fi
    else
        info "Pass --install to run: brew install xcode-build-server"
    fi
else
    info "Neither SwiftPM nor an Xcode project at $workspace_root — build-server bridge not applicable."
fi

# -------- summary -----------------------------------------------------------

echo
if [[ $EXIT -eq 0 ]]; then
    echo "$(green 'All checks passed.') You're ready to use xcindex_* tools in Claude Code."
else
    echo "$(red 'Some checks failed.') See remediation hints above."
fi
exit $EXIT
